# Python
__pycache__/
*.pyc
*.pyo

# PyInstaller build output
build/
dist/
installer_output/

# Local runtime config — contains real server credentials/API keys.
# assets/config.json is auto-created with safe defaults on first run
# (see ConfigManager._ensure_config_file); nothing to template here.
assets/config.json

# Runtime-generated logs/debug dumps
crash.log
error.txt
play_history_debug.json
assets/metrics.db

# Trust-on-first-use SSH host key store (see core/ssh_manager.py) —
# machine-specific trust state, not something to template or share.
assets/known_hosts

# Editor/OS cruft
.vscode/
.idea/
Thumbs.db
